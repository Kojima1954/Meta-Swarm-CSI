# ═══════════════════════════════════════════════════════════════
#  N.O.M.A.D. Swarm Intelligence — Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ─── Domain & Identity ───
DOMAIN=swarm.example.org
NODE_ID=node-alpha
NODE_NAME=Node Alpha

# ─── N.O.M.A.D. Docker Network (auto-detected) ───
NOMAD_NETWORK=project-nomad_default

# ─── Compose Profiles ───
# Set to "self-managed" if Ollama/Qdrant are NOT installed via N.O.M.A.D. UI
# Leave empty if N.O.M.A.D. manages them
COMPOSE_PROFILES=self-managed

# ─── Image Versions (pin for reproducibility) ───
OLLAMA_IMAGE=ollama/ollama:latest
QDRANT_IMAGE=qdrant/qdrant:latest
CONDUIT_IMAGE=matrixconduit/matrix-conduit:latest
ELEMENT_IMAGE=vectorim/element-web:latest
GOTOSOCIAL_IMAGE=superseriousbusiness/gotosocial:latest
NGINX_IMAGE=nginx:1.27-alpine

# ─── AI Models ───
LLM_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text

# ─── Matrix ───
MATRIX_ADMIN_PASSWORD=changeme

# ─── GoToSocial ───
GOTOSOCIAL_ADMIN_EMAIL=admin@example.org

# ─── Swarm Rounds ───
ROUND_MODE=timer
ROUND_INTERVAL=300
MESSAGE_THRESHOLD=50
